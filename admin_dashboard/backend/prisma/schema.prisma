generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ViTri {
  ma_vi_tri   String     @id @db.VarChar(10)
  ten_chuc_vu String     @db.VarChar(50)
  luong       Decimal    @db.Decimal(12, 2)
  nhanviens   NhanVien[]

  @@map("vitri")
}

model CuaHang {
  ma_ch     String     @id @db.VarChar(10)
  ten_ch    String     @db.VarChar(100)
  dia_chi   String     @db.VarChar(200)
  sdt       String     @unique(map: "sdt") @db.VarChar(15)
  email     String     @unique(map: "email") @db.VarChar(100)
  nhanviens NhanVien[]

  @@map("cuahang")
}

model KhachHang {
  ma_kh           String   @id @db.VarChar(20)
  ho_ten_kh       String   @db.VarChar(100)
  dia_chi         String   @db.VarChar(200)
  sdt             String   @unique(map: "sdt") @db.VarChar(15)
  email           String   @unique(map: "email") @db.VarChar(100)
  diem_tich_luy   Int?     @default(0)
  hang_thanh_vien String?  @default("Thành viên mới") @db.VarChar(50)
  hoadons         HoaDon[]

  @@map("khachhang")
}

model NhaCungCap {
  ma_ncc     String      @id @db.VarChar(10)
  ten_ncc    String      @db.VarChar(100)
  dia_chi    String      @db.VarChar(200)
  sdt        String      @unique(map: "sdt") @db.VarChar(15)
  email      String      @unique(map: "email") @db.VarChar(100)
  phieunhaps PhieuNhap[]
  sanphams   SanPham[]

  @@map("nhacungcap")
}

model NhanVien {
  ma_nv        String      @id @db.VarChar(10)
  ho_ten_nv    String      @db.VarChar(100)
  ngay_sinh    DateTime    @db.Date
  gioi_tinh    String      @db.VarChar(10)
  dia_chi      String      @db.VarChar(200)
  sdt          String      @unique(map: "sdt") @db.VarChar(15)
  email        String      @unique(map: "email") @db.VarChar(100)
  ngay_vao_lam DateTime    @db.Date
  ma_vi_tri    String      @db.VarChar(10)
  ma_ch        String      @db.VarChar(10)
  hoadons      HoaDon[]
  vitri        ViTri       @relation(fields: [ma_vi_tri], references: [ma_vi_tri], onDelete: NoAction, onUpdate: NoAction, map: "nhanvien_ibfk_1")
  cuahang      CuaHang     @relation(fields: [ma_ch], references: [ma_ch], onDelete: NoAction, onUpdate: NoAction, map: "nhanvien_ibfk_2")
  phieunhaps   PhieuNhap[]

  @@index([ma_ch], map: "ma_ch")
  @@index([ma_vi_tri], map: "ma_vi_tri")
  @@map("nhanvien")
}

model SanPham {
  ma_sp      String       @id @db.VarChar(10)
  ten_sp     String       @db.VarChar(100)
  danh_muc   String       @db.VarChar(50)
  chat_lieu  String       @db.VarChar(100)
  mua_vu     String       @db.VarChar(50)
  gioi_tinh  String       @db.VarChar(10)
  ma_ncc     String       @db.VarChar(10)
  bienthes   BienTheSKU[]
  nhacungcap NhaCungCap   @relation(fields: [ma_ncc], references: [ma_ncc], onDelete: NoAction, onUpdate: NoAction, map: "sanpham_ibfk_1")

  @@index([ma_ncc], map: "ma_ncc")
  @@map("sanpham")
}

model BienTheSKU {
  ma_sku            String             @id @db.VarChar(30)
  ma_sp             String             @db.VarChar(10)
  mau_sac           String             @db.VarChar(50)
  kich_co           String             @db.VarChar(20)
  gia_ban           Decimal            @db.Decimal(15, 2)
  so_luong_ton      Int                @default(0)
  sanpham           SanPham            @relation(fields: [ma_sp], references: [ma_sp], onDelete: NoAction, onUpdate: NoAction, map: "bienthesku_ibfk_1")
  chitietHoaDons    ChiTietHoaDon[]
  chitietPhieuNhaps ChiTietPhieuNhap[]

  @@index([ma_sp], map: "ma_sp")
  @@map("bienthesku")
}

model PhieuNhap {
  ma_pn      String             @id @db.VarChar(10)
  ngay_nhap  DateTime           @db.Date
  tong_tien  Decimal            @db.Decimal(15, 2)
  ma_ncc     String             @db.VarChar(10)
  ma_nv      String             @db.VarChar(10)
  chitiet    ChiTietPhieuNhap[]
  nhacungcap NhaCungCap         @relation(fields: [ma_ncc], references: [ma_ncc], onDelete: NoAction, onUpdate: NoAction, map: "phieunhap_ibfk_1")
  nhanvien   NhanVien           @relation(fields: [ma_nv], references: [ma_nv], onDelete: NoAction, onUpdate: NoAction, map: "phieunhap_ibfk_2")

  @@index([ma_ncc], map: "ma_ncc")
  @@index([ma_nv], map: "ma_nv")
  @@map("phieunhap")
}

model HoaDon {
  ma_hd                  String          @id @db.VarChar(10)
  ngay_tao               DateTime        @db.Date
  tong_tien              Decimal         @db.Decimal(15, 2)
  phuong_thuc_thanh_toan String          @db.VarChar(50)
  trang_thai             String          @db.VarChar(20)
  ma_kh                  String          @db.VarChar(20)
  ma_nv                  String          @db.VarChar(10)
  chitiet                ChiTietHoaDon[]
  khachhang              KhachHang       @relation(fields: [ma_kh], references: [ma_kh], onDelete: NoAction, onUpdate: NoAction, map: "hoadon_ibfk_1")
  nhanvien               NhanVien        @relation(fields: [ma_nv], references: [ma_nv], onDelete: NoAction, onUpdate: NoAction, map: "hoadon_ibfk_2")

  @@index([ma_kh], map: "ma_kh")
  @@index([ma_nv], map: "ma_nv")
  @@map("hoadon")
}

model ChiTietHoaDon {
  ma_hd    String     @db.VarChar(10)
  ma_sku   String     @db.VarChar(30)
  so_luong Int
  gia_ban  Decimal    @db.Decimal(15, 2)
  hoadon   HoaDon     @relation(fields: [ma_hd], references: [ma_hd], onDelete: NoAction, onUpdate: NoAction, map: "chitiethoadon_ibfk_1")
  sku      BienTheSKU @relation(fields: [ma_sku], references: [ma_sku], onDelete: NoAction, onUpdate: NoAction, map: "chitiethoadon_ibfk_2")

  @@id([ma_hd, ma_sku])
  @@index([ma_sku], map: "ma_sku")
  @@map("chitiethoadon")
}

model ChiTietPhieuNhap {
  ma_pn     String     @db.VarChar(10)
  ma_sku    String     @db.VarChar(30)
  so_luong  Int
  gia_nhap  Decimal    @db.Decimal(15, 2)
  phieunhap PhieuNhap  @relation(fields: [ma_pn], references: [ma_pn], onDelete: NoAction, onUpdate: NoAction, map: "chitietphieunhap_ibfk_1")
  sku       BienTheSKU @relation(fields: [ma_sku], references: [ma_sku], onDelete: NoAction, onUpdate: NoAction, map: "chitietphieunhap_ibfk_2")

  @@id([ma_pn, ma_sku])
  @@index([ma_sku], map: "ma_sku")
  @@map("chitietphieunhap")
}

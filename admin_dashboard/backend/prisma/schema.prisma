generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ViTri {
  ma_vi_tri   String    @id
  ten_chuc_vu String
  luong       Decimal
  nhanviens   NhanVien[]

  @@map("vitri")
}

model CuaHang {
  ma_ch    String    @id
  ten_ch   String
  dia_chi  String
  sdt      String    @unique
  email    String    @unique
  nhanviens NhanVien[]

  @@map("cuahang")
}

model NhaCungCap {
  ma_ncc     String     @id
  ten_ncc    String
  dia_chi    String
  sdt        String     @unique
  email      String     @unique
  sanphams   SanPham[]
  phieunhaps PhieuNhap[]

  @@map("nhacungcap")
}

model KhachHang {
  ma_kh          String   @id
  ho_ten_kh      String
  dia_chi        String
  sdt            String   @unique
  email          String   @unique
  diem_tich_luy  Int      @default(0)
  hang_thanh_vien String  @default("Thành viên mới")
  hoadons        HoaDon[]

  @@map("khachhang")
}

model NhanVien {
  ma_nv       String   @id
  ho_ten_nv   String
  ngay_sinh   DateTime
  gioi_tinh   String
  dia_chi     String
  sdt         String   @unique
  email       String   @unique
  ngay_vao_lam DateTime
  ma_vi_tri   String
  ma_ch       String

  vitri       ViTri    @relation(fields: [ma_vi_tri], references: [ma_vi_tri])
  cuahang     CuaHang  @relation(fields: [ma_ch], references: [ma_ch])
  phieunhaps  PhieuNhap[]
  hoadons     HoaDon[]

  @@map("nhanvien")
}

model SanPham {
  ma_sp     String      @id
  ten_sp    String
  danh_muc  String
  chat_lieu String
  mua_vu    String
  gioi_tinh String
  ma_ncc    String

  nhacungcap NhaCungCap @relation(fields: [ma_ncc], references: [ma_ncc])
  bienthes   BienTheSKU[]

  @@map("sanpham")
}

model BienTheSKU {
  ma_sku      String   @id
  ma_sp       String
  mau_sac     String
  kich_co     String
  gia_ban     Decimal
  so_luong_ton Int     @default(0)

  sanpham     SanPham  @relation(fields: [ma_sp], references: [ma_sp])
  chitietHoaDons ChiTietHoaDon[]
  chitietPhieuNhaps ChiTietPhieuNhap[]

  @@map("bienthesku")
}

model PhieuNhap {
  ma_pn     String   @id
  ngay_nhap DateTime
  tong_tien Decimal
  ma_ncc    String
  ma_nv     String

  nhacungcap NhaCungCap @relation(fields: [ma_ncc], references: [ma_ncc])
  nhanvien   NhanVien   @relation(fields: [ma_nv], references: [ma_nv])
  chitiet    ChiTietPhieuNhap[]

  @@map("phieunhap")
}

model HoaDon {
  ma_hd                 String   @id
  ngay_tao              DateTime
  tong_tien             Decimal
  phuong_thuc_thanh_toan String
  trang_thai            String
  ma_kh                 String
  ma_nv                 String

  khachhang             KhachHang @relation(fields: [ma_kh], references: [ma_kh])
  nhanvien              NhanVien  @relation(fields: [ma_nv], references: [ma_nv])
  chitiet               ChiTietHoaDon[]

  @@map("hoadon")
}

model ChiTietPhieuNhap {
  ma_pn    String
  ma_sku   String
  so_luong Int
  gia_nhap Decimal

  phieunhap PhieuNhap @relation(fields: [ma_pn], references: [ma_pn])
  sku       BienTheSKU @relation(fields: [ma_sku], references: [ma_sku])

  @@id([ma_pn, ma_sku])
  @@map("chitietphieunhap")
}

model ChiTietHoaDon {
  ma_hd    String
  ma_sku   String
  so_luong Int
  gia_ban  Decimal

  hoadon   HoaDon    @relation(fields: [ma_hd], references: [ma_hd])
  sku      BienTheSKU @relation(fields: [ma_sku], references: [ma_sku])

  @@id([ma_hd, ma_sku])
  @@map("chitiethoadon")
}

